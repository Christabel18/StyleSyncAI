# ─────────────────────────────────────────────────────────────
# StyleSync AI — environment variables
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored. Never commit real keys.
# ─────────────────────────────────────────────────────────────

# Frontend (P1) ------------------------------------------------
# Mock mode runs the whole UI with built-in demo data — no backend needed.
# Set to "false" once P2/P3's /api routes are live. This is also the
# instant "swap to fixtures" switch for the demo.
NEXT_PUBLIC_MOCK_MODE=true

# Supabase (client-readable — P4 provides these)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Backend / server-only (owned by P2 + P4) ---------------------
# These are NOT exposed to the browser. Used by the /api routes.
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
AZURE_OPENAI_API_KEY=your_azure_openai_key
AZURE_OPENAI_ENDPOINT=your_azure_openai_endpoint
