# Azure AI Vision
AZURE_VISION_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_VISION_KEY=your-key

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Frontend (P1)
# Mock mode runs the whole UI with built-in demo data — no backend needed.
# Set to "false" once /api/analyze and /api/recommend are live.
# This is also the instant demo safety-net swap described in the hackathon plan.
NEXT_PUBLIC_MOCK_MODE=true
